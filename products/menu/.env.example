# Menu dev template — copy to `.env.local`, fill in.
# `.env.local` is gitignored; `.env.example` is the tracked source of truth.

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/menu

# Menu public URL — used to build the OIDC redirect_uri + CORS origin.
MENU_PUBLIC_URL=http://localhost:3000

# Menu session-cookie encryption key (jose, dir / A256GCM). >= 32 chars.
# Generate with: openssl rand -base64 48. In production this is minted by
# `random_password.menu_session_secret` (infra/tofu/zitadel.tf), so dev
# is the only place a human picks a value.
MENU_SESSION_SECRET=

# Zitadel OIDC client credentials. In production these come from
# `zitadel_application_oidc.menu` outputs (infra/tofu/zitadel.tf). For
# dev, run a local Zitadel (docker compose) or point at a shared dev
# instance and paste the values from its Console.
ZITADEL_ISSUER_URL=http://localhost:8080
ZITADEL_OAUTH_CLIENT_ID=
ZITADEL_OAUTH_CLIENT_SECRET=

# PAT for menu's IAM_OWNER service account. Used by the identity slice
# for org provisioning + membership lookups. In production minted by
# `zitadel_personal_access_token.menu_sa` (TF). For dev: create a
# machine user with IAM_OWNER in the local Zitadel console and paste its PAT.
ZITADEL_MANAGEMENT_TOKEN=

# Object storage (S3-compatible: LocalStack local, R2/S3 in prod)
S3_ENDPOINT=http://localhost:4566
S3_REGION=us-east-1
S3_ACCESS_KEY=test
S3_SECRET_KEY=test
S3_BUCKET=menu

# OpenTelemetry / observability ----------------------------------------------
# OTLP HTTP endpoint that the @iedora/observability SDK ships spans to.
# Production points at the shared `infra-openobserve` container on the
# `kamal` Docker network. Append `/api/<org>` — OpenObserve serves OTLP
# under that org-scoped path. Leave blank in local dev unless you've
# started a collector — the SDK degrades to a "logs once at boot, never
# exports" mode when unset.
# Production: http://infra-openobserve:5080/api/default
OTEL_EXPORTER_OTLP_ENDPOINT=

# OTLP ingest auth — `Authorization=Basic%20<base64(email:password)>`.
# URL-encoded form: spaces → %20.
OTEL_EXPORTER_OTLP_HEADERS=

# Git SHA — CI passes this at build time via --build-arg GIT_SHA=…
# Becomes the `service.version` resource attribute. Local dev: leave blank.
GIT_SHA=

# Per-host name. Becomes the `host.name` resource attribute so cross-
# product traces can filter by host. Local dev: leave blank.
HOST_NAME=
